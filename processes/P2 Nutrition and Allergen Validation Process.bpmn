<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_NutritionAllergenValidation" targetNamespace="http://nutriprep.example/bpmn" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_NutritionAllergenValidation" name="Nutrition and Allergen Validation Process">
    <bpmn:participant id="Participant_NutriPrep" name="Nutri Prep" processRef="Process_NutritionAllergenValidation" />
  </bpmn:collaboration>
  <bpmn:process id="Process_NutritionAllergenValidation" name="Nutrition and Allergen Validation Process" isExecutable="true">
    <bpmn:laneSet id="LaneSet_NutritionAllergenValidation">
      <bpmn:lane id="Lane_HeadNutritionist" name="Head Nutritionist">
        <bpmn:flowNodeRef>UserTask_ApproveMealForMenu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_AdjustRecipeOrPortion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ReviewNutritionTargets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_PrepareNutritionData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_MealDataReady</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_FoodQualityAssistant" name="Food Quality Assistant">
        <bpmn:flowNodeRef>Gateway_LabelsCorrect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_FixAllergenLabels</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_CheckIngredientAllergens</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_OrderingSystem" name="Ordering System">
        <bpmn:flowNodeRef>Gateway_1cj7ug8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CalculateNutritionValues</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NutritionOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CompareAllergensWithLabels</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_PublishValidatedMealData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0sl6qxu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ValidationCompleted</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_PrepareNutritionData_To_CalculateNutritionValues" sourceRef="UserTask_PrepareNutritionData" targetRef="Gateway_1cj7ug8" />
    <bpmn:sequenceFlow id="Flow_CalculateNutritionValues_To_ReviewNutritionTargets" sourceRef="ServiceTask_CalculateNutritionValues" targetRef="UserTask_ReviewNutritionTargets" />
    <bpmn:sequenceFlow id="Flow_ReviewNutritionTargets_To_NutritionOk" sourceRef="UserTask_ReviewNutritionTargets" targetRef="Gateway_NutritionOk" />
    <bpmn:sequenceFlow id="Flow_NutritionOk_No_To_AdjustRecipe" name="No" sourceRef="Gateway_NutritionOk" targetRef="UserTask_AdjustRecipeOrPortion">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${nutritionOk == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdjustRecipe_To_CalculateNutritionValues" sourceRef="UserTask_AdjustRecipeOrPortion" targetRef="Gateway_1cj7ug8" />
    <bpmn:sequenceFlow id="Flow_NutritionOk_Yes_To_CheckIngredientAllergens" name="Yes" sourceRef="Gateway_NutritionOk" targetRef="UserTask_CheckIngredientAllergens">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${nutritionOk == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CompareAllergens_To_LabelsCorrect" sourceRef="ServiceTask_CompareAllergensWithLabels" targetRef="Gateway_LabelsCorrect" />
    <bpmn:sequenceFlow id="Flow_LabelsCorrect_No_To_FixLabels" name="No" sourceRef="Gateway_LabelsCorrect" targetRef="UserTask_FixAllergenLabels">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${labelsCorrect == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_FixLabels_To_CompareAllergens" sourceRef="UserTask_FixAllergenLabels" targetRef="Gateway_0sl6qxu" />
    <bpmn:sequenceFlow id="Flow_LabelsCorrect_Yes_To_ApproveMeal" name="Yes" sourceRef="Gateway_LabelsCorrect" targetRef="UserTask_ApproveMealForMenu">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${labelsCorrect == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CheckIngredientAllergens_To_CompareAllergens" sourceRef="UserTask_CheckIngredientAllergens" targetRef="Gateway_0sl6qxu" />
    <bpmn:sequenceFlow id="Flow_ApproveMeal_To_PublishValidatedMealData" sourceRef="UserTask_ApproveMealForMenu" targetRef="ServiceTask_PublishValidatedMealData" />
    <bpmn:sequenceFlow id="Flow_PublishValidatedMealData_To_End" sourceRef="ServiceTask_PublishValidatedMealData" targetRef="EndEvent_ValidationCompleted" />
    <bpmn:dataObjectReference id="DataObjectReference_AllergenList" name="Allergen list" dataObjectRef="DataObject_AllergenList" />
    <bpmn:dataObject id="DataObject_AllergenList" name="Allergen list" />
    <bpmn:exclusiveGateway id="Gateway_LabelsCorrect" name="Allergen labels correct?">
      <bpmn:incoming>Flow_CompareAllergens_To_LabelsCorrect</bpmn:incoming>
      <bpmn:outgoing>Flow_LabelsCorrect_No_To_FixLabels</bpmn:outgoing>
      <bpmn:outgoing>Flow_LabelsCorrect_Yes_To_ApproveMeal</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_11bbwee" sourceRef="Gateway_1cj7ug8" targetRef="ServiceTask_CalculateNutritionValues" />
    <bpmn:userTask id="UserTask_FixAllergenLabels" name="Fix allergen labels">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_LabelsCorrect_No_To_FixLabels</bpmn:incoming>
      <bpmn:outgoing>Flow_FixLabels_To_CompareAllergens</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_Start_To_PrepareNutritionData" sourceRef="StartEvent_MealDataReady" targetRef="UserTask_PrepareNutritionData" />
    <bpmn:exclusiveGateway id="Gateway_1cj7ug8">
      <bpmn:incoming>Flow_AdjustRecipe_To_CalculateNutritionValues</bpmn:incoming>
      <bpmn:incoming>Flow_PrepareNutritionData_To_CalculateNutritionValues</bpmn:incoming>
      <bpmn:outgoing>Flow_11bbwee</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_CalculateNutritionValues" name="Calculate nutrition values" camunda:type="external" camunda:topic="calculate-nutrition-values">
      <bpmn:incoming>Flow_11bbwee</bpmn:incoming>
      <bpmn:outgoing>Flow_CalculateNutritionValues_To_ReviewNutritionTargets</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0nhkcqx">
        <bpmn:targetRef>DataObjectReference_NutritionProfile</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_NutritionProfile" name="Nutrition profile" dataObjectRef="DataObject_NutritionProfile" />
    <bpmn:dataObject id="DataObject_NutritionProfile" name="Nutrition profile" />
    <bpmn:exclusiveGateway id="Gateway_NutritionOk" name="Nutrition OK?">
      <bpmn:incoming>Flow_ReviewNutritionTargets_To_NutritionOk</bpmn:incoming>
      <bpmn:outgoing>Flow_NutritionOk_No_To_AdjustRecipe</bpmn:outgoing>
      <bpmn:outgoing>Flow_NutritionOk_Yes_To_CheckIngredientAllergens</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_CompareAllergensWithLabels" name="Compare allergens with meal labels" camunda:type="external" camunda:topic="compare-allergens-with-labels">
      <bpmn:incoming>Flow_1qjiho0</bpmn:incoming>
      <bpmn:outgoing>Flow_CompareAllergens_To_LabelsCorrect</bpmn:outgoing>
      <bpmn:property id="Property_0mvvqda" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0qhlpsi">
        <bpmn:sourceRef>DataObjectReference_MealLabel</bpmn:sourceRef>
        <bpmn:targetRef>Property_0mvvqda</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_MealLabel" name="Meal label" dataObjectRef="DataObject_MealLabel" />
    <bpmn:dataObject id="DataObject_MealLabel" name="Meal label" />
    <bpmn:serviceTask id="ServiceTask_PublishValidatedMealData" name="Publish validated meal data" camunda:type="external" camunda:topic="publish-validated-meal-data">
      <bpmn:incoming>Flow_ApproveMeal_To_PublishValidatedMealData</bpmn:incoming>
      <bpmn:outgoing>Flow_PublishValidatedMealData_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0sl6qxu">
      <bpmn:incoming>Flow_CheckIngredientAllergens_To_CompareAllergens</bpmn:incoming>
      <bpmn:incoming>Flow_FixLabels_To_CompareAllergens</bpmn:incoming>
      <bpmn:outgoing>Flow_1qjiho0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1qjiho0" sourceRef="Gateway_0sl6qxu" targetRef="ServiceTask_CompareAllergensWithLabels" />
    <bpmn:userTask id="UserTask_CheckIngredientAllergens" name="Check ingredient allergen list">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NutritionOk_Yes_To_CheckIngredientAllergens</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckIngredientAllergens_To_CompareAllergens</bpmn:outgoing>
      <bpmn:property id="Property_0k9ypg2" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_02xnnmh">
        <bpmn:sourceRef>DataObjectReference_AllergenList</bpmn:sourceRef>
        <bpmn:targetRef>Property_0k9ypg2</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_ApproveMealForMenu" name="Approve meal for menu">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_LabelsCorrect_Yes_To_ApproveMeal</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveMeal_To_PublishValidatedMealData</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_AdjustRecipeOrPortion" name="Adjust recipe or portion">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NutritionOk_No_To_AdjustRecipe</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustRecipe_To_CalculateNutritionValues</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_ReviewNutritionTargets" name="Review nutrition targets">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CalculateNutritionValues_To_ReviewNutritionTargets</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewNutritionTargets_To_NutritionOk</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_PrepareNutritionData" name="Prepare meal nutrition data">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_PrepareNutritionData</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareNutritionData_To_CalculateNutritionValues</bpmn:outgoing>
      <bpmn:property id="Property_0uo7hke" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1mmg6wc">
        <bpmn:sourceRef>DataObjectReference_Recipe</bpmn:sourceRef>
        <bpmn:targetRef>Property_0uo7hke</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_MealDataReady" name="Meal data ready">
      <bpmn:outgoing>Flow_Start_To_PrepareNutritionData</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:dataObjectReference id="DataObjectReference_Recipe" name="Recipe" dataObjectRef="DataObject_Recipe" />
    <bpmn:dataObject id="DataObject_Recipe" name="Recipe" />
    <bpmn:endEvent id="EndEvent_ValidationCompleted" name="Meal validation completed">
      <bpmn:incoming>Flow_PublishValidatedMealData_To_End</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateEventDefinition_0rmwhre" />
    </bpmn:endEvent>
  </bpmn:process>
