<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_SupplierOrderingInventoryReplenishment" targetNamespace="http://nutriprep.example/bpmn" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_SupplierOrderingInventoryReplenishment" name="Supplier Ordering and Inventory Replenishment Process">
    <bpmn:participant id="Participant_Supplier" name="Supplier" />
    <bpmn:participant id="Participant_NutriPrep" name="Nutri Prep" processRef="Process_SupplierOrderingInventoryReplenishment" />
    <bpmn:messageFlow id="MessageFlow_SupplierConfirmation" name="Supplier confirmation" sourceRef="Participant_Supplier" targetRef="IntermediateCatchEvent_SupplierConfirmationReceived" />
    <bpmn:messageFlow id="MessageFlow_DeliveryNote" name="Delivery note / ingredients" sourceRef="Participant_Supplier" targetRef="IntermediateCatchEvent_DeliveryReceived" />
    <bpmn:messageFlow id="MessageFlow_SupplierIssueReport" name="Supplier issue report" sourceRef="SendTask_ReportSupplierIssue" targetRef="Participant_Supplier" />
    <bpmn:messageFlow id="MessageFlow_SupplierOrder" name="Supplier order" sourceRef="Event_11xhv5n" targetRef="Participant_Supplier" />
  </bpmn:collaboration>
  <bpmn:process id="Process_SupplierOrderingInventoryReplenishment" name="Supplier Ordering and Inventory Replenishment Process" isExecutable="true">
    <bpmn:laneSet id="LaneSet_SupplierOrderingInventoryReplenishment">
      <bpmn:lane id="Lane_OperationsManager" name="Operations Manager">
        <bpmn:flowNodeRef>UserTask_ReviewPurchaseRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_SelectAlternativeSupplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_16jxucs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_FoodQualityAssistant" name="Food Quality Assistant">
        <bpmn:flowNodeRef>UserTask_ReceiveIngredients</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_CheckQualityAndQuantity</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0c4wa18</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DeliveryOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1hs9hkp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_12u20hd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_StoreIngredients</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_InventoryReplenished</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_13sf0af</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0x1g4sk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1vc5t9m</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_OrderingSystem" name="Ordering System">
        <bpmn:flowNodeRef>Gateway_1o5xqh1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_UpdateInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_PurchaseRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CreateSupplierOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatchEvent_SupplierConfirmationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SupplierConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatchEvent_DeliveryReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_ReportSupplierIssue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_11xhv5n</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="UserTask_ReceiveIngredients" name="Receive ingredients">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_DeliveryReceived_To_ReceiveIngredients</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveIngredients_To_CheckQualityAndQuantity</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_CheckQualityAndQuantity" name="Check quality and quantity">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ReceiveIngredients_To_CheckQualityAndQuantity</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckQualityAndQuantity_To_DeliveryOk</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_Start_To_ReviewPurchaseRequest" sourceRef="StartEvent_PurchaseRequestReceived" targetRef="UserTask_ReviewPurchaseRequest" />
    <bpmn:sequenceFlow id="Flow_ReviewPurchaseRequest_To_CreateSupplierOrder" sourceRef="UserTask_ReviewPurchaseRequest" targetRef="Gateway_16jxucs" />
    <bpmn:sequenceFlow id="Flow_SupplierConfirmed_No_To_SelectAlternativeSupplier" name="No" sourceRef="Gateway_SupplierConfirmed" targetRef="UserTask_SelectAlternativeSupplier">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${supplierConfirmed == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SelectAlternativeSupplier_To_CreateSupplierOrder" sourceRef="UserTask_SelectAlternativeSupplier" targetRef="Gateway_16jxucs" />
    <bpmn:sequenceFlow id="Flow_DeliveryReceived_To_ReceiveIngredients" sourceRef="IntermediateCatchEvent_DeliveryReceived" targetRef="UserTask_ReceiveIngredients" />
    <bpmn:sequenceFlow id="Flow_ReceiveIngredients_To_CheckQualityAndQuantity" sourceRef="UserTask_ReceiveIngredients" targetRef="UserTask_CheckQualityAndQuantity" />
    <bpmn:sequenceFlow id="Flow_CheckQualityAndQuantity_To_DeliveryOk" sourceRef="UserTask_CheckQualityAndQuantity" targetRef="Gateway_DeliveryOk" />
    <bpmn:sequenceFlow id="Flow_0hyevfp" sourceRef="Gateway_16jxucs" targetRef="ServiceTask_CreateSupplierOrder" />
    <bpmn:sequenceFlow id="Flow_DeliveryOk_Yes_To_UpdateInventory" name="Yes" sourceRef="Gateway_DeliveryOk" targetRef="Gateway_1o5xqh1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${deliveryOk == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1cbz47v" sourceRef="Activity_0c4wa18" targetRef="SendTask_ReportSupplierIssue" />
    <bpmn:sequenceFlow id="Flow_DeliveryOk_No_To_ReportSupplierIssue" name="No" sourceRef="Gateway_DeliveryOk" targetRef="Activity_0c4wa18">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${deliveryOk == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ReportSupplierIssue_To_ReviewDeliveryIssue" name="Yes" sourceRef="Gateway_12u20hd" targetRef="Activity_1vc5t9m" />
    <bpmn:sequenceFlow id="Flow_0pt83fj" sourceRef="Gateway_1o5xqh1" targetRef="ServiceTask_UpdateInventory" />
    <bpmn:sequenceFlow id="Flow_UpdateInventory_To_StoreIngredients" sourceRef="ServiceTask_UpdateInventory" targetRef="UserTask_StoreIngredients" />
    <bpmn:sequenceFlow id="Flow_StoreIngredients_To_End" sourceRef="UserTask_StoreIngredients" targetRef="EndEvent_InventoryReplenished" />
    <bpmn:userTask id="Activity_0c4wa18" name="Record delivery issue">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_DeliveryOk_No_To_ReportSupplierIssue</bpmn:incoming>
      <bpmn:outgoing>Flow_1cbz47v</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_177yhzo">
        <bpmn:targetRef>DataObjectReference_0okqqz6</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_DeliveryOk" name="Delivery OK?">
      <bpmn:incoming>Flow_CheckQualityAndQuantity_To_DeliveryOk</bpmn:incoming>
      <bpmn:outgoing>Flow_DeliveryOk_No_To_ReportSupplierIssue</bpmn:outgoing>
      <bpmn:outgoing>Flow_DeliveryOk_Yes_To_UpdateInventory</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_1o5xqh1">
      <bpmn:incoming>Flow_DeliveryOk_Yes_To_UpdateInventory</bpmn:incoming>
      <bpmn:incoming>Flow_1abv88q</bpmn:incoming>
      <bpmn:outgoing>Flow_0pt83fj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_UpdateInventory" name="Update inventory" camunda:type="external" camunda:topic="update-inventory">
      <bpmn:incoming>Flow_0pt83fj</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateInventory_To_StoreIngredients</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0bddu6j">
        <bpmn:targetRef>DataObjectReference_InventoryRecord</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_ReviewPurchaseRequest" name="Review purchase request">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_ReviewPurchaseRequest</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPurchaseRequest_To_CreateSupplierOrder</bpmn:outgoing>
      <bpmn:property id="Property_0jwp5yi" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_19w8yxv">
        <bpmn:sourceRef>DataObjectReference_PurchaseRequest</bpmn:sourceRef>
        <bpmn:targetRef>Property_0jwp5yi</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_SelectAlternativeSupplier" name="Select alternative supplier">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SupplierConfirmed_No_To_SelectAlternativeSupplier</bpmn:incoming>
      <bpmn:outgoing>Flow_SelectAlternativeSupplier_To_CreateSupplierOrder</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_16jxucs">
      <bpmn:incoming>Flow_ReviewPurchaseRequest_To_CreateSupplierOrder</bpmn:incoming>
      <bpmn:incoming>Flow_SelectAlternativeSupplier_To_CreateSupplierOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_0hyevfp</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:dataObjectReference id="DataObjectReference_PurchaseRequest" name="Purchase request" dataObjectRef="DataObject_PurchaseRequest" />
    <bpmn:dataObject id="DataObject_PurchaseRequest" name="Purchase request" />
    <bpmn:dataObjectReference id="DataObjectReference_0okqqz6" name="Delivery issue" dataObjectRef="DataObject_0sdjtan" />
    <bpmn:dataObject id="DataObject_0sdjtan" />
    <bpmn:sequenceFlow id="Flow_0z68vo1" sourceRef="SendTask_ReportSupplierIssue" targetRef="Activity_1hs9hkp" />
    <bpmn:sequenceFlow id="Flow_0e1qdg1" sourceRef="Activity_1hs9hkp" targetRef="Gateway_12u20hd" />
    <bpmn:userTask id="Activity_1hs9hkp" name="Decide accepted items">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0z68vo1</bpmn:incoming>
      <bpmn:outgoing>Flow_0e1qdg1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_12u20hd" name="Any items accepted?">
      <bpmn:incoming>Flow_0e1qdg1</bpmn:incoming>
      <bpmn:outgoing>Flow_ReportSupplierIssue_To_ReviewDeliveryIssue</bpmn:outgoing>
      <bpmn:outgoing>Flow_0jcn3j2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_StoreIngredients" name="Store ingredients">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_UpdateInventory_To_StoreIngredients</bpmn:incoming>
      <bpmn:outgoing>Flow_StoreIngredients_To_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_InventoryReplenished" name="Inventory replenished">
      <bpmn:incoming>Flow_StoreIngredients_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0jcn3j2" name="No" sourceRef="Gateway_12u20hd" targetRef="Activity_0x1g4sk" />
    <bpmn:sequenceFlow id="Flow_1abv88q" sourceRef="Activity_1vc5t9m" targetRef="Gateway_1o5xqh1" />
    <bpmn:startEvent id="StartEvent_PurchaseRequestReceived" name="Purchase request received">
      <bpmn:outgoing>Flow_Start_To_ReviewPurchaseRequest</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_CreateSupplierOrder" name="Create supplier order" camunda:type="external" camunda:topic="create-supplier-order">
      <bpmn:incoming>Flow_0hyevfp</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateSupplierOrder_To_SendSupplierOrder</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0ecgb9y">
        <bpmn:targetRef>DataObjectReference_SupplierOrder</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_SupplierConfirmation" name="Supplier confirmation" dataObjectRef="DataObject_SupplierConfirmation" />
    <bpmn:dataObject id="DataObject_SupplierConfirmation" name="Supplier confirmation" />
    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_SupplierConfirmationReceived" name="Supplier confirmation received">
      <bpmn:incoming>Flow_0pmqp58</bpmn:incoming>
      <bpmn:outgoing>Flow_SupplierConfirmationReceived_To_SupplierConfirmed</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1xsnwi5">
        <bpmn:targetRef>DataObjectReference_SupplierConfirmation</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:messageEventDefinition id="MessageEventDefinition_SupplierConfirmation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_SupplierConfirmed" name="Supplier confirmed order?">
      <bpmn:incoming>Flow_SupplierConfirmationReceived_To_SupplierConfirmed</bpmn:incoming>
      <bpmn:outgoing>Flow_SupplierConfirmed_No_To_SelectAlternativeSupplier</bpmn:outgoing>
      <bpmn:outgoing>Flow_SupplierConfirmed_Yes_To_DeliveryReceived</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:dataObjectReference id="DataObjectReference_DeliveryNote" name="Delivery note" dataObjectRef="DataObject_DeliveryNote" />
    <bpmn:dataObject id="DataObject_DeliveryNote" name="Delivery note" />
    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_DeliveryReceived" name="Delivery received">
      <bpmn:incoming>Flow_SupplierConfirmed_Yes_To_DeliveryReceived</bpmn:incoming>
      <bpmn:outgoing>Flow_DeliveryReceived_To_ReceiveIngredients</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_10m4otv">
        <bpmn:targetRef>DataObjectReference_DeliveryNote</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:messageEventDefinition id="MessageEventDefinition_DeliveryReceived" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_CreateSupplierOrder_To_SendSupplierOrder" sourceRef="ServiceTask_CreateSupplierOrder" targetRef="Event_11xhv5n" />
    <bpmn:sequenceFlow id="Flow_SupplierConfirmationReceived_To_SupplierConfirmed" sourceRef="IntermediateCatchEvent_SupplierConfirmationReceived" targetRef="Gateway_SupplierConfirmed" />
    <bpmn:sequenceFlow id="Flow_SupplierConfirmed_Yes_To_DeliveryReceived" name="Yes" sourceRef="Gateway_SupplierConfirmed" targetRef="IntermediateCatchEvent_DeliveryReceived">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${supplierConfirmed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:dataObjectReference id="DataObjectReference_SupplierOrder" name="Supplier order" dataObjectRef="DataObject_SupplierOrder" />
    <bpmn:dataObject id="DataObject_SupplierOrder" name="Supplier order" />
    <bpmn:dataObjectReference id="DataObjectReference_InventoryRecord" name="Inventory record" dataObjectRef="DataObject_InventoryRecord" />
    <bpmn:dataObject id="DataObject_InventoryRecord" name="Inventory record" />
    <bpmn:sendTask id="SendTask_ReportSupplierIssue" name="Report supplier issue">
      <bpmn:incoming>Flow_1cbz47v</bpmn:incoming>
      <bpmn:outgoing>Flow_0z68vo1</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_13sf0af" name="Replenishment failed">
      <bpmn:incoming>Flow_0q9xfuo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0q9xfuo" sourceRef="Activity_0x1g4sk" targetRef="Event_13sf0af" />
    <bpmn:userTask id="Activity_0x1g4sk" name="Return delivery">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jcn3j2</bpmn:incoming>
      <bpmn:outgoing>Flow_0q9xfuo</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_1vc5t9m" name="Return rejected ingredients">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ReportSupplierIssue_To_ReviewDeliveryIssue</bpmn:incoming>
      <bpmn:outgoing>Flow_1abv88q</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0pmqp58" sourceRef="Event_11xhv5n" targetRef="IntermediateCatchEvent_SupplierConfirmationReceived" />
    <bpmn:intermediateThrowEvent id="Event_11xhv5n" name="Supplier order">
      <bpmn:incoming>Flow_CreateSupplierOrder_To_SendSupplierOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_0pmqp58</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0vnfkst" />
    </bpmn:intermediateThrowEvent>
  </bpmn:process>
