      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataObjectReference_Recipe" name="Recipe" dataObjectRef="DataObject_Recipe" />
    <bpmn:dataObject id="DataObject_Recipe" name="Recipe" />
    <bpmn:userTask id="UserTask_CookMeals" name="Cook meals">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="cooking-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=preparationChecklist" target="preparationChecklist" />
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=true" target="cookingComplete" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PrepareIngredients_To_CookMeals</bpmn:incoming>
      <bpmn:outgoing>Flow_CookMeals_To_PortionAndPack</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1u0mw9z">
      <bpmn:incoming>Flow_ReworkMeals_To_PortionAndPack</bpmn:incoming>
      <bpmn:incoming>Flow_CookMeals_To_PortionAndPack</bpmn:incoming>
      <bpmn:outgoing>Flow_036gklg</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:dataObjectReference id="DataObjectReference_PackedMeal" name="Packed meal" dataObjectRef="DataObject_PackedMeal" />
    <bpmn:dataObject id="DataObject_PackedMeal" name="Packed meal" />
    <bpmn:userTask id="UserTask_PortionAndPackMeals" name="Portion and pack meals">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="packaging-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=true" target="packedMeal" />
          <zeebe:output source="=1" target="affectedMeals" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_036gklg</bpmn:incoming>
      <bpmn:outgoing>Flow_PortionAndPack_To_CheckPortionFreshness</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0o3ou70">
        <bpmn:targetRef>DataObjectReference_PackedMeal</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:subProcess id="Activity_0avq6st" name="Quality control subprocess">
      <bpmn:incoming>Flow_PortionAndPack_To_CheckPortionFreshness</bpmn:incoming>
      <bpmn:outgoing>Flow_1bqtqan</bpmn:outgoing>
      <bpmn:startEvent id="Event_0wzoo88" name="Start quality control">
        <bpmn:outgoing>Flow_1066765</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="Activity_0b9z8qt" name="Check portions">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="check-portions-form" />
          <zeebe:ioMapping>
            <zeebe:input source="=batchId" target="batchId" />
            <zeebe:input source="=preparationChecklist" target="preparationChecklist" />
            <zeebe:output source="=portionsOk" target="portionsOk" />
            <zeebe:output source="=portionsIssue" target="portionsIssue" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_08tdz6t</bpmn:incoming>
        <bpmn:outgoing>Flow_1wlnwzh</bpmn:outgoing>
        <bpmn:property id="Property_0cbr1ke" name="__targetRef_placeholder" />
        <bpmn:dataInputAssociation id="DataInputAssociation_15awfkj">
          <bpmn:sourceRef>DataObjectReference_QualityChecklist</bpmn:sourceRef>
          <bpmn:targetRef>Property_0cbr1ke</bpmn:targetRef>
        </bpmn:dataInputAssociation>
      </bpmn:userTask>
      <bpmn:dataObjectReference id="DataObjectReference_QualityChecklist" name="Quality control checklist" dataObjectRef="DataObject_0q7vabr" />
      <bpmn:dataObject id="DataObject_0q7vabr" />
      <bpmn:endEvent id="Event_1ld47zh" name="End quality control">
        <bpmn:incoming>Flow_00j8std</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1066765" sourceRef="Event_0wzoo88" targetRef="Gateway_0rbts21" />
      <bpmn:sequenceFlow id="Flow_08tdz6t" sourceRef="Gateway_0rbts21" targetRef="Activity_0b9z8qt" />
      <bpmn:parallelGateway id="Gateway_0rbts21">
        <bpmn:incoming>Flow_1066765</bpmn:incoming>
        <bpmn:outgoing>Flow_08tdz6t</bpmn:outgoing>
        <bpmn:outgoing>Flow_0jimam4</bpmn:outgoing>
        <bpmn:outgoing>Flow_1ebwnmx</bpmn:outgoing>
      </bpmn:parallelGateway>
      <bpmn:sequenceFlow id="Flow_0jimam4" sourceRef="Gateway_0rbts21" targetRef="Activity_0j6uxh9" />
      <bpmn:sequenceFlow id="Flow_1ebwnmx" sourceRef="Gateway_0rbts21" targetRef="Activity_16lkkv3" />
      <bpmn:sequenceFlow id="Flow_002usp6" sourceRef="Activity_0j6uxh9" targetRef="Gateway_0m92acm" />
      <bpmn:sequenceFlow id="Flow_1wlnwzh" sourceRef="Activity_0b9z8qt" targetRef="Gateway_0m92acm" />
      <bpmn:sequenceFlow id="Flow_12ia68j" sourceRef="Activity_16lkkv3" targetRef="Gateway_0m92acm" />
      <bpmn:sequenceFlow id="Flow_00j8std" sourceRef="Gateway_0m92acm" targetRef="Event_1ld47zh" />
      <bpmn:parallelGateway id="Gateway_0m92acm">
        <bpmn:incoming>Flow_002usp6</bpmn:incoming>
        <bpmn:incoming>Flow_1wlnwzh</bpmn:incoming>
        <bpmn:incoming>Flow_12ia68j</bpmn:incoming>
        <bpmn:outgoing>Flow_00j8std</bpmn:outgoing>
      </bpmn:parallelGateway>
      <bpmn:userTask id="Activity_16lkkv3" name="Check labels and allergens">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="check-labels-allergens-form" />
          <zeebe:ioMapping>
            <zeebe:input source="=batchId" target="batchId" />
            <zeebe:output source="=labelsOk" target="labelsOk" />
            <zeebe:output source="=labelsIssue" target="labelsIssue" />
            <zeebe:output source="=portionsOk and freshnessOk and labelsOk" target="qualityOk" />
            <zeebe:output source="=portionsIssue + &#34; | &#34; + freshnessIssue + &#34; | &#34; + labelsIssue" target="qualityIssue" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1ebwnmx</bpmn:incoming>
        <bpmn:outgoing>Flow_12ia68j</bpmn:outgoing>
        <bpmn:property id="Property_1k75ta4" name="__targetRef_placeholder" />
        <bpmn:dataInputAssociation id="DataInputAssociation_0rdm23v">
          <bpmn:sourceRef>DataObjectReference_QualityChecklist</bpmn:sourceRef>
          <bpmn:targetRef>Property_1k75ta4</bpmn:targetRef>
        </bpmn:dataInputAssociation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Activity_0j6uxh9" name="Check freshness" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://mocka.ouim.me/mock/b8d68716/api/fresh" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultVariable" value="freshnessOk" />
            <zeebe:header key="resultExpression" value="=response.body" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0jimam4</bpmn:incoming>
        <bpmn:outgoing>Flow_002usp6</bpmn:outgoing>
        <bpmn:property id="Property_0k4dq6k" name="__targetRef_placeholder" />
        <bpmn:dataInputAssociation id="DataInputAssociation_09z900e">
          <bpmn:sourceRef>DataObjectReference_QualityChecklist</bpmn:sourceRef>
          <bpmn:targetRef>Property_0k4dq6k</bpmn:targetRef>
        </bpmn:dataInputAssociation>
      </bpmn:serviceTask>
    </bpmn:subProcess>
    <bpmn:userTask id="UserTask_MoveMealsToDispatchArea" name="Move meals to dispatch area">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="dispatch-area-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=true" target="movedToDispatch" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_UpdateBatchStatus_To_MoveMealsToDispatch</bpmn:incoming>
      <bpmn:outgoing>Flow_MoveMealsToDispatch_To_MarkReady</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_QualityOk" name="Quality control OK?">
      <bpmn:incoming>Flow_1bqtqan</bpmn:incoming>
      <bpmn:outgoing>Flow_QualityOk_Yes_To_UpdateBatchStatus</bpmn:outgoing>
      <bpmn:outgoing>Flow_QualityOk_No_To_ReworkPossible</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ReworkMeals" name="Rework meals">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="rework-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=reworkType" target="reworkType" />
          <zeebe:input source="=extraTimeMinutes" target="extraTimeMinutes" />
          <zeebe:output source="=true" target="reworkComplete" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ReworkPossible_Yes_To_DecideRework</bpmn:incoming>
      <bpmn:outgoing>Flow_ReworkMeals_To_PortionAndPack</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_DecideReworkAction" name="Decide rework action">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="decide-rework-action" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId " target="batchId" />
          <zeebe:input source="=productionDate " target="productionDate" />
          <zeebe:input source="=affectedMeals " target="affectedMeals" />
          <zeebe:input source="=qualityIssue " target="qualityIssue" />
          <zeebe:input source="=rejectionReason" target="rejectionReason" />
          <zeebe:output source="=reworkPossible " target="reworkPossible" />
          <zeebe:output source="=reworkType" target="reworkType" />
          <zeebe:output source="=extraTimeMinutes" target="extraTimeMinutes" />
          <zeebe:output source="=extraResources" target="extraResources" />
          <zeebe:output source="=rejectionReason" target="rejectionReason" />
          <zeebe:output source="=reworkNotes" target="reworkNotes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_QualityOk_No_To_ReworkPossible</bpmn:incoming>
      <bpmn:outgoing>Flow_DecideRework_To_ReworkMeals</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ReworkPossible" name="Rework possible?">
      <bpmn:incoming>Flow_DecideRework_To_ReworkMeals</bpmn:incoming>
      <bpmn:outgoing>Flow_ReworkPossible_Yes_To_DecideRework</bpmn:outgoing>
      <bpmn:outgoing>Flow_ReworkPossible_No_To_RecordRejectedBatch</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_RecordRejectedBatch" name="Record rejected batch">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="record-rejected-batch-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=affectedMeals" target="affectedMeals" />
          <zeebe:input source="=qualityIssue" target="qualityIssue" />
          <zeebe:input source="=rejectionReason" target="rejectionReason" />
          <zeebe:output source="=rejectionCategory" target="rejectionCategory" />
          <zeebe:output source="=costLoss" target="costLoss" />
          <zeebe:output source="=true" target="incidentRecorded" />
          <zeebe:output source="=&#34;INC-&#34; + string(batchId)" target="incidentId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ReworkPossible_No_To_RecordRejectedBatch</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordRejectedBatch_To_BatchRejected</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_BatchRejected" name="Meal batch rejected">
      <bpmn:incoming>Flow_RecordRejectedBatch_To_BatchRejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ServiceTask_UpdateMealBatchStatus" name="Update meal batch status" camunda:type="external" camunda:topic="update-meal-batch-status">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="update-batch-status" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=qualityOk" target="qualityOk" />
          <zeebe:input source="=reworkPossible" target="reworkPossible" />
          <zeebe:output source="=batchStatus" target="batchStatus" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_QualityOk_Yes_To_UpdateBatchStatus</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateBatchStatus_To_MoveMealsToDispatch</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_MarkMealsReadyForDispatch" name="Mark meals ready for dispatch" camunda:type="external" camunda:topic="mark-meals-ready-for-dispatch">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="mark-meals-ready" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=dispatchReady" target="dispatchReady" />
          <zeebe:output source="=readyAt" target="readyAt" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_MoveMealsToDispatch_To_MarkReady</bpmn:incoming>
      <bpmn:outgoing>Flow_MarkReady_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_MealsReadyForDispatch" name="Meals ready for dispatch">
      <bpmn:incoming>Flow_MarkReady_To_End</bpmn:incoming>
    </bpmn:endEvent>
