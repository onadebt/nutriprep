<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_DemandForecastingIngredientPlanning" targetNamespace="http://nutriprep.example/bpmn" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_DemandForecastingIngredientPlanning" name="Demand Forecasting and Ingredient Planning Process">
    <bpmn:participant id="Participant_NutriPrep" name="Nutri Prep" processRef="Process_DemandForecastingIngredientPlanning" />
    <bpmn:textAnnotation id="TextAnnotation_06qbkse">
      <bpmn:text>Every day at 8:00 a.m.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0mepz9c" associationDirection="None" sourceRef="StartEvent_PlanningPeriodStarted" targetRef="TextAnnotation_06qbkse" />
  </bpmn:collaboration>
  <bpmn:process id="Process_DemandForecastingIngredientPlanning" name="Demand Forecasting and Ingredient Planning Process" isExecutable="true">
    <bpmn:laneSet id="LaneSet_DemandForecastingIngredientPlanning">
      <bpmn:lane id="Lane_OperationsManager" name="Operations Manager">
        <bpmn:flowNodeRef>UserTask_ReviewConfirmedOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ApproveIngredientPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_PlanningPeriodStarted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1d33u14</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1gt5g76</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_AdjustForecastAssumptions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PlanningCompleted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_KitchenManager" name="Kitchen Manager">
        <bpmn:flowNodeRef>UserTask_ReviewKitchenCapacity</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_AdjustProductionPlan</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_OrderingSystem" name="Ordering System">
        <bpmn:flowNodeRef>ServiceTask_LoadConfirmedOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CalculateDemandForecast</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CheckInventoryLevels</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ForecastFeasible</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_IngredientsAvailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_018hqcv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CreateIngredientPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GeneratePurchaseRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0degooa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_PublishPlanningOutputs</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="UserTask_ReviewConfirmedOrders" name="Review confirmed orders">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_LoadConfirmedOrders_To_ReviewConfirmedOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewConfirmedOrders_To_CalculateDemandForecast</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_Start_To_LoadConfirmedOrders" sourceRef="StartEvent_PlanningPeriodStarted" targetRef="ServiceTask_LoadConfirmedOrders" />
    <bpmn:sequenceFlow id="Flow_LoadConfirmedOrders_To_ReviewConfirmedOrders" sourceRef="ServiceTask_LoadConfirmedOrders" targetRef="UserTask_ReviewConfirmedOrders" />
    <bpmn:sequenceFlow id="Flow_ReviewConfirmedOrders_To_CalculateDemandForecast" sourceRef="UserTask_ReviewConfirmedOrders" targetRef="Gateway_0degooa" />
    <bpmn:sequenceFlow id="Flow_CalculateDemandForecast_To_ReviewKitchenCapacity" sourceRef="ServiceTask_CalculateDemandForecast" targetRef="UserTask_ReviewKitchenCapacity" />
    <bpmn:sequenceFlow id="Flow_ReviewKitchenCapacity_To_ForecastFeasible" sourceRef="UserTask_ReviewKitchenCapacity" targetRef="Gateway_ForecastFeasible" />
    <bpmn:sequenceFlow id="Flow_ForecastFeasible_No_To_AdjustForecast" name="No" sourceRef="Gateway_ForecastFeasible" targetRef="Gateway_1gt5g76">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${forecastFeasible == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdjustForecast_To_AdjustProductionPlan" sourceRef="UserTask_AdjustForecastAssumptions" targetRef="UserTask_AdjustProductionPlan" />
    <bpmn:sequenceFlow id="Flow_AdjustProductionPlan_To_CalculateDemandForecast" sourceRef="UserTask_AdjustProductionPlan" targetRef="Gateway_0degooa" />
    <bpmn:sequenceFlow id="Flow_CreateIngredientPlan_To_ApproveIngredientPlan" sourceRef="ServiceTask_CreateIngredientPlan" targetRef="UserTask_ApproveIngredientPlan" />
    <bpmn:sequenceFlow id="Flow_ApproveIngredientPlan_To_PublishPlanningOutputs" name="Yes" sourceRef="Gateway_1d33u14" targetRef="ServiceTask_PublishPlanningOutputs" />
    <bpmn:sequenceFlow id="Flow_PublishPlanningOutputs_To_End" sourceRef="ServiceTask_PublishPlanningOutputs" targetRef="EndEvent_PlanningCompleted" />
    <bpmn:sequenceFlow id="Flow_13xhftw" sourceRef="Gateway_0degooa" targetRef="ServiceTask_CalculateDemandForecast" />
    <bpmn:serviceTask id="ServiceTask_LoadConfirmedOrders" name="Load confirmed orders" camunda:type="external" camunda:topic="load-confirmed-orders">
      <bpmn:incoming>Flow_Start_To_LoadConfirmedOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadConfirmedOrders_To_ReviewConfirmedOrders</bpmn:outgoing>
      <bpmn:property id="Property_08ftcwl" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1ku8lvg">
        <bpmn:sourceRef>DataObjectReference_ConfirmedOrdersReport</bpmn:sourceRef>
        <bpmn:targetRef>Property_08ftcwl</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_CalculateDemandForecast" name="Calculate demand forecast" camunda:type="external" camunda:topic="calculate-demand-forecast">
      <bpmn:incoming>Flow_13xhftw</bpmn:incoming>
      <bpmn:outgoing>Flow_CalculateDemandForecast_To_ReviewKitchenCapacity</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0c3pj9s">
        <bpmn:targetRef>DataObjectReference_DemandForecast</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_CheckInventoryLevels" name="Check inventory levels" camunda:type="external" camunda:topic="check-inventory-levels">
      <bpmn:incoming>Flow_ForecastFeasible_Yes_To_CheckInventory</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckInventory_To_IngredientsAvailable</bpmn:outgoing>
      <bpmn:property id="Property_0gf9fz6" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1lyojlg">
        <bpmn:sourceRef>DataObjectReference_InventoryRecord</bpmn:sourceRef>
        <bpmn:targetRef>Property_0gf9fz6</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ForecastFeasible" name="Forecast feasible?">
      <bpmn:incoming>Flow_ReviewKitchenCapacity_To_ForecastFeasible</bpmn:incoming>
      <bpmn:outgoing>Flow_ForecastFeasible_No_To_AdjustForecast</bpmn:outgoing>
      <bpmn:outgoing>Flow_ForecastFeasible_Yes_To_CheckInventory</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_IngredientsAvailable" name="Enough ingredients in stock?">
      <bpmn:incoming>Flow_CheckInventory_To_IngredientsAvailable</bpmn:incoming>
      <bpmn:outgoing>Flow_IngredientsAvailable_No_To_GeneratePurchaseRequest</bpmn:outgoing>
      <bpmn:outgoing>Flow_IngredientsAvailable_Yes_To_CreateIngredientPlan</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_ForecastFeasible_Yes_To_CheckInventory" name="Yes" sourceRef="Gateway_ForecastFeasible" targetRef="ServiceTask_CheckInventoryLevels">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${forecastFeasible == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CheckInventory_To_IngredientsAvailable" sourceRef="ServiceTask_CheckInventoryLevels" targetRef="Gateway_IngredientsAvailable" />
    <bpmn:sequenceFlow id="Flow_IngredientsAvailable_No_To_GeneratePurchaseRequest" name="No" sourceRef="Gateway_IngredientsAvailable" targetRef="ServiceTask_GeneratePurchaseRequest">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${ingredientsAvailable == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_IngredientsAvailable_Yes_To_CreateIngredientPlan" name="Yes" sourceRef="Gateway_IngredientsAvailable" targetRef="Gateway_018hqcv">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${ingredientsAvailable == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GeneratePurchaseRequest_To_CreateIngredientPlan" sourceRef="ServiceTask_GeneratePurchaseRequest" targetRef="Gateway_018hqcv" />
    <bpmn:dataObjectReference id="DataObjectReference_DemandForecast" name="Demand forecast" dataObjectRef="DataObject_DemandForecast" />
    <bpmn:dataObject id="DataObject_DemandForecast" name="Demand forecast" />
    <bpmn:userTask id="UserTask_ReviewKitchenCapacity" name="Review kitchen capacity">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CalculateDemandForecast_To_ReviewKitchenCapacity</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewKitchenCapacity_To_ForecastFeasible</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataObjectReference_InventoryRecord" name="Inventory record" dataObjectRef="DataObject_InventoryRecord" />
    <bpmn:dataObject id="DataObject_InventoryRecord" name="Inventory record" />
    <bpmn:sequenceFlow id="Flow_0zjhz5l" sourceRef="Gateway_018hqcv" targetRef="ServiceTask_CreateIngredientPlan" />
    <bpmn:exclusiveGateway id="Gateway_018hqcv">
      <bpmn:incoming>Flow_IngredientsAvailable_Yes_To_CreateIngredientPlan</bpmn:incoming>
      <bpmn:incoming>Flow_GeneratePurchaseRequest_To_CreateIngredientPlan</bpmn:incoming>
      <bpmn:outgoing>Flow_0zjhz5l</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_CreateIngredientPlan" name="Create ingredient plan" camunda:type="external" camunda:topic="create-ingredient-plan">
      <bpmn:incoming>Flow_0zjhz5l</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateIngredientPlan_To_ApproveIngredientPlan</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_12wkfvv">
        <bpmn:targetRef>DataObjectReference_IngredientPlan</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_GeneratePurchaseRequest" name="Generate purchase request" camunda:type="external" camunda:topic="generate-purchase-request">
      <bpmn:incoming>Flow_IngredientsAvailable_No_To_GeneratePurchaseRequest</bpmn:incoming>
      <bpmn:outgoing>Flow_GeneratePurchaseRequest_To_CreateIngredientPlan</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1pfn2vy">
        <bpmn:targetRef>DataObjectReference_PurchaseRequest</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_PurchaseRequest" name="Purchase request" dataObjectRef="DataObject_PurchaseRequest" />
    <bpmn:dataObject id="DataObject_PurchaseRequest" name="Purchase request" />
    <bpmn:dataObjectReference id="DataObjectReference_IngredientPlan" name="Ingredient plan" dataObjectRef="DataObject_IngredientPlan" />
    <bpmn:dataObject id="DataObject_IngredientPlan" name="Ingredient plan" />
    <bpmn:dataObjectReference id="DataObjectReference_ConfirmedOrdersReport" name="Confirmed orders report" dataObjectRef="DataObject_ConfirmedOrdersReport" />
    <bpmn:dataObject id="DataObject_ConfirmedOrdersReport" name="Confirmed orders report" />
    <bpmn:exclusiveGateway id="Gateway_0degooa">
      <bpmn:incoming>Flow_ReviewConfirmedOrders_To_CalculateDemandForecast</bpmn:incoming>
      <bpmn:incoming>Flow_AdjustProductionPlan_To_CalculateDemandForecast</bpmn:incoming>
      <bpmn:outgoing>Flow_13xhftw</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ApproveIngredientPlan" name="Approve ingredient plan">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CreateIngredientPlan_To_ApproveIngredientPlan</bpmn:incoming>
      <bpmn:outgoing>Flow_046p4zh</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_PlanningPeriodStarted" name="Daily planning started">
      <bpmn:outgoing>Flow_Start_To_LoadConfirmedOrders</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0d00b3m" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_1d33u14" name="Ingredient plan approved?">
      <bpmn:incoming>Flow_046p4zh</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveIngredientPlan_To_PublishPlanningOutputs</bpmn:outgoing>
      <bpmn:outgoing>Flow_0iikesz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_046p4zh" sourceRef="UserTask_ApproveIngredientPlan" targetRef="Gateway_1d33u14" />
    <bpmn:serviceTask id="ServiceTask_PublishPlanningOutputs" name="Publish ingredient and production plan" camunda:type="external" camunda:topic="publish-planning-outputs">
      <bpmn:incoming>Flow_ApproveIngredientPlan_To_PublishPlanningOutputs</bpmn:incoming>
      <bpmn:outgoing>Flow_PublishPlanningOutputs_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1i38rzq" sourceRef="Gateway_1gt5g76" targetRef="UserTask_AdjustForecastAssumptions" />
    <bpmn:exclusiveGateway id="Gateway_1gt5g76">
      <bpmn:incoming>Flow_ForecastFeasible_No_To_AdjustForecast</bpmn:incoming>
      <bpmn:incoming>Flow_0iikesz</bpmn:incoming>
      <bpmn:outgoing>Flow_1i38rzq</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_AdjustForecastAssumptions" name="Adjust forecast assumptions">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1i38rzq</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustForecast_To_AdjustProductionPlan</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_AdjustProductionPlan" name="Adjust production plan">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AdjustForecast_To_AdjustProductionPlan</bpmn:incoming>
      <bpmn:outgoing>Flow_AdjustProductionPlan_To_CalculateDemandForecast</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0iikesz" name="No" sourceRef="Gateway_1d33u14" targetRef="Gateway_1gt5g76" />
    <bpmn:endEvent id="EndEvent_PlanningCompleted" name="Ingredient planning completed">
      <bpmn:incoming>Flow_PublishPlanningOutputs_To_End</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DemandForecastingIngredientPlanning">
