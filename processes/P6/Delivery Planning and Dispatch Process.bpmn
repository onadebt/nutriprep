<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_DeliveryPlanningDispatch" targetNamespace="http://nutriprep.example/bpmn" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collaboration_DeliveryPlanningDispatch" name="Delivery Planning and Dispatch Process">
    <bpmn:participant id="Participant_Customer" name="Customer" />
    <bpmn:participant id="Participant_NutriPrep" name="Nutri Prep" processRef="Process_qlnyvpm" />
    <bpmn:messageFlow id="MessageFlow_DeliveryFailedNotice" name="Delivery failed notice" sourceRef="EndEvent_DeliveryFailed" targetRef="Participant_Customer" />
    <bpmn:messageFlow id="MessageFlow_DeliveryConfirmation" name="Delivery confirmation" sourceRef="EndEvent_DeliveryCompleted" targetRef="Participant_Customer" />
    <bpmn:messageFlow id="MessageFlow_DeliveryDelayNotice" name="Delivery delay notice" sourceRef="Activity_01gpftq" targetRef="Participant_Customer" />
  </bpmn:collaboration>
  <bpmn:process id="Process_qlnyvpm" name="Delivery Planning and Dispatch Process" isExecutable="true">
    <bpmn:laneSet id="LaneSet_DeliveryPlanningDispatch">
      <bpmn:lane id="Lane_OrderingSystem" name="Ordering System">
        <bpmn:flowNodeRef>ServiceTask_LoadPackedOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1k4eiy1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GenerateDeliveryRoutes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_UpdateDispatchStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DeliveryCompleted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_01gpftq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_NotificationCompleted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DeliveryFailed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_CustomerSupport" name="Customer Support">
        <bpmn:flowNodeRef>Activity_07rb12m</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DeliveryTeam" name="Delivery Team">
        <bpmn:flowNodeRef>UserTask_DeliverOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RoutesFeasible</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_LoadOrdersForDelivery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1ox5pie</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ContactCustomer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RedeliveryPossible</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1en7of0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_00l0ahb</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_OperationsManager" name="Operations Manager">
        <bpmn:flowNodeRef>UserTask_ReviewDeliveryProblem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1mt5ckl</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ReviewOrdersReadyForDelivery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_MealsReady</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="UserTask_DeliverOrders" name="Deliver orders">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="deliver-orders-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=deliveryRoute" target="deliveryRouteId" />
          <zeebe:output source="=deliverySuccessful" target="deliverySuccessful" />
          <zeebe:output source="=deliveryFailureReason" target="deliveryFailureReason" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0d53rqg</bpmn:incoming>
      <bpmn:outgoing>Flow_0axfkhe</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_LoadPackedOrders" name="Load packed orders" camunda:type="external" camunda:topic="load-packed-orders">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="load-packed-orders" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=packedOrders" target="packedOrders" />
          <zeebe:output source="=packedOrdersCount" target="packedOrdersCount" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_LoadPackedOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadPackedOrders_To_ReviewOrders</bpmn:outgoing>
      <bpmn:property id="Property_0bhiiuq" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1avgdr7">
        <bpmn:sourceRef>DataObjectReference_PackedOrders</bpmn:sourceRef>
        <bpmn:targetRef>Property_0bhiiuq</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_PackedOrders" name="Packed orders" dataObjectRef="DataObject_PackedOrders" />
    <bpmn:dataObject id="DataObject_PackedOrders" name="Packed orders" />
    <bpmn:serviceTask id="Activity_1k4eiy1" name="Check weather conditions" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="https://api.open-meteo.com/v1/forecast?latitude=52.52&#38;longitude=16.6&#38;current=temperature_2m,rain&#38;timezone=Europe%2FBerlin" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={weather:&#10;  {rain: response.body.current.rain,&#10;   temp: response.body.current.temperature_2m&#10;  }&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_07pt5a5</bpmn:incoming>
      <bpmn:outgoing>Flow_0gw6ren</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_RoutesFeasible" name="Routes feasible?">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_GenerateRoutes_To_RoutesFeasible</bpmn:incoming>
      <bpmn:outgoing>Flow_RoutesFeasible_No_To_ReviewProblem</bpmn:outgoing>
      <bpmn:outgoing>Flow_RoutesFeasible_Yes_To_LoadOrders</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_GenerateDeliveryRoutes" name="Generate delivery routes" camunda:type="external" camunda:topic="generate-delivery-routes">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generate_route" />
        <zeebe:properties />
        <zeebe:ioMapping>
          <zeebe:output source="=if weather.rain = 1 then false else true" target="routesFeasible" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0gw6ren</bpmn:incoming>
      <bpmn:outgoing>Flow_GenerateRoutes_To_RoutesFeasible</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1pyjm0d">
        <bpmn:targetRef>DataObjectReference_DeliveryRoute</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_DeliveryRoute" name="Delivery route" dataObjectRef="DataObject_DeliveryRoute" />
    <bpmn:dataObject id="DataObject_DeliveryRoute" name="Delivery route" />
    <bpmn:serviceTask id="ServiceTask_UpdateDispatchStatus" name="Update dispatch status" camunda:type="external" camunda:topic="update-dispatch-status">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="update-dispatch-status" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=deliveryRoute" target="deliveryRoute" />
          <zeebe:output source="=dispatchStatus" target="dispatchStatus" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_LoadOrders_To_UpdateDispatchStatus</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateDispatchStatus_To_DeliverOrders</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_08dj085">
        <bpmn:targetRef>DataObjectReference_DeliveryStatus</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_LoadOrdersForDelivery" name="Load orders for delivery">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="load-orders-delivery-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=true" target="ordersLoaded" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RoutesFeasible_Yes_To_LoadOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadOrders_To_UpdateDispatchStatus</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataObjectReference_DeliveryStatus" name="Delivery status" dataObjectRef="DataObject_DeliveryStatus" />
    <bpmn:dataObject id="DataObject_DeliveryStatus" name="Delivery status" />
    <bpmn:exclusiveGateway id="Gateway_1ox5pie">
      <bpmn:incoming>Flow_UpdateDispatchStatus_To_DeliverOrders</bpmn:incoming>
      <bpmn:incoming>Flow_RedeliveryPossible_Yes_To_AttemptRedelivery</bpmn:incoming>
      <bpmn:outgoing>Flow_0d53rqg</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ReviewDeliveryProblem" name="Review delivery capacity issue">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="review-delivery-capacity-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=affectedOrderCount" target="affectedOrderCount" />
          <zeebe:output source="=capacityAction" target="capacityAction" />
          <zeebe:output source="=capacityNotes" target="capacityNotes" />
          <zeebe:output source="=true" target="capacityResolved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RoutesFeasible_No_To_ReviewProblem</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewProblem_To_GenerateRoutes</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1mt5ckl">
      <bpmn:incoming>Flow_ReviewProblem_To_GenerateRoutes</bpmn:incoming>
      <bpmn:incoming>Flow_18w4u31</bpmn:incoming>
      <bpmn:outgoing>Flow_07pt5a5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ReviewOrdersReadyForDelivery" name="Review orders ready for delivery">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="review-orders-ready-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:input source="=packedOrdersCount" target="packedOrdersCount" />
          <zeebe:output source="=reviewNotes" target="reviewNotes" />
          <zeebe:output source="=true" target="ordersReviewed" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_LoadPackedOrders_To_ReviewOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_18w4u31</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_MealsReady" name="Meals ready for dispatch">
      <bpmn:outgoing>Flow_Start_To_LoadPackedOrders</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_DeliveryCompleted" name="Delivery completed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="delivery_completed" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0axfkhe</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1i7674g" />
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_07rb12m" name="Compose delivery delay notification">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="delivery-delay-notification-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=customerName" target="customerName" />
          <zeebe:input source="=customerEmail" target="customerEmail" />
          <zeebe:input source="=orderId" target="orderId" />
          <zeebe:input source="=batchId" target="batchId" />
          <zeebe:output source="=mailFrom" target="mailFrom" />
          <zeebe:output source="=mailTo" target="mailTo" />
          <zeebe:output source="=mailSubject" target="mailSubject" />
          <zeebe:output source="=delayReason" target="delayReason" />
          <zeebe:output source="=delayMinutes" target="delayMinutes" />
          <zeebe:output source="=mailBody" target="mailBody" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1xgpebs</bpmn:incoming>
      <bpmn:outgoing>Flow_12rjwu7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_01gpftq" name="Send delivery delay notice" zeebe:modelerTemplate="io.camunda.connectors.email.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="nutriprep@seznam.cz" target="authentication.username" />
          <zeebe:input source="pP2-dpjc9q.cYr3" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="smtp.seznam.cz" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=465" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="TLS" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="nutriprep@seznam.cz" target="data.smtpAction.from" />
          <zeebe:input source="=mailTo" target="data.smtpAction.to" />
          <zeebe:input source="=mailSubject" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="=&#34;Dear &#34; + customerName + &#34;,\n\nYour order &#34; + orderId + &#34; is delayed by &#34; + string(delayMinutes) + &#34; minutes.\n\nReason: &#34; + delayReason + &#34;\n\n&#34; + mailBody + &#34;\n\nNutri Prep team&#34;" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.email.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_12rjwu7</bpmn:incoming>
      <bpmn:outgoing>Flow_0jdmtiw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_NotificationCompleted" name="Customer notified of delay">
      <bpmn:incoming>Flow_0jdmtiw</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="UserTask_ContactCustomer" name="Contact customer">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="contact-customer-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=customerName" target="customerName" />
          <zeebe:input source="=customerPhone" target="customerPhone" />
          <zeebe:input source="=customerEmail" target="customerEmail" />
          <zeebe:input source="=orderId" target="orderId" />
          <zeebe:output source="=contactMethod" target="contactMethod" />
          <zeebe:output source="=customerReached" target="customerReached" />
          <zeebe:output source="=contactNotes" target="contactNotes" />
          <zeebe:output source="=customerReached" target="redeliveryPossible" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1y8rt93</bpmn:incoming>
      <bpmn:outgoing>Flow_ContactCustomer_To_RedeliveryPossible</bpmn:outgoing>
      <bpmn:property id="Property_0iq0z99" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0b40f3y">
        <bpmn:sourceRef>DataObjectReference_CustomerContact</bpmn:sourceRef>
        <bpmn:targetRef>Property_0iq0z99</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataObjectReference_CustomerContact" name="Customer contact details" dataObjectRef="DataObject_CustomerContact" />
    <bpmn:dataObject id="DataObject_CustomerContact" name="Customer contact details" />
    <bpmn:exclusiveGateway id="Gateway_RedeliveryPossible" name="Redelivery possible?">
      <bpmn:incoming>Flow_ContactCustomer_To_RedeliveryPossible</bpmn:incoming>
      <bpmn:outgoing>Flow_RedeliveryPossible_Yes_To_AttemptRedelivery</bpmn:outgoing>
      <bpmn:outgoing>Flow_RedeliveryPossible_No_To_SendFailedNotice</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:boundaryEvent id="Event_1en7of0" name="60 minutes" cancelActivity="false" attachedToRef="UserTask_DeliverOrders">
      <bpmn:outgoing>Flow_1xgpebs</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_02v51i2">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_00l0ahb" name="Delivery problem" attachedToRef="UserTask_DeliverOrders">
      <bpmn:outgoing>Flow_1y8rt93</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_15trjc6" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0d53rqg" sourceRef="Gateway_1ox5pie" targetRef="UserTask_DeliverOrders" />
    <bpmn:sequenceFlow id="Flow_0axfkhe" sourceRef="UserTask_DeliverOrders" targetRef="EndEvent_DeliveryCompleted" />
    <bpmn:sequenceFlow id="Flow_Start_To_LoadPackedOrders" sourceRef="StartEvent_MealsReady" targetRef="ServiceTask_LoadPackedOrders" />
    <bpmn:sequenceFlow id="Flow_LoadPackedOrders_To_ReviewOrders" sourceRef="ServiceTask_LoadPackedOrders" targetRef="UserTask_ReviewOrdersReadyForDelivery" />
    <bpmn:sequenceFlow id="Flow_07pt5a5" sourceRef="Gateway_1mt5ckl" targetRef="Activity_1k4eiy1" />
    <bpmn:sequenceFlow id="Flow_0gw6ren" sourceRef="Activity_1k4eiy1" targetRef="ServiceTask_GenerateDeliveryRoutes" />
    <bpmn:sequenceFlow id="Flow_GenerateRoutes_To_RoutesFeasible" sourceRef="ServiceTask_GenerateDeliveryRoutes" targetRef="Gateway_RoutesFeasible" />
    <bpmn:sequenceFlow id="Flow_RoutesFeasible_Yes_To_LoadOrders" name="Yes" sourceRef="Gateway_RoutesFeasible" targetRef="UserTask_LoadOrdersForDelivery">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=routesFeasible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RoutesFeasible_No_To_ReviewProblem" name="No" sourceRef="Gateway_RoutesFeasible" targetRef="UserTask_ReviewDeliveryProblem">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=routesFeasible = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_LoadOrders_To_UpdateDispatchStatus" sourceRef="UserTask_LoadOrdersForDelivery" targetRef="ServiceTask_UpdateDispatchStatus" />
    <bpmn:sequenceFlow id="Flow_UpdateDispatchStatus_To_DeliverOrders" sourceRef="ServiceTask_UpdateDispatchStatus" targetRef="Gateway_1ox5pie" />
    <bpmn:sequenceFlow id="Flow_RedeliveryPossible_Yes_To_AttemptRedelivery" name="Yes" sourceRef="Gateway_RedeliveryPossible" targetRef="Gateway_1ox5pie">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=redeliveryPossible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ReviewProblem_To_GenerateRoutes" sourceRef="UserTask_ReviewDeliveryProblem" targetRef="Gateway_1mt5ckl" />
    <bpmn:sequenceFlow id="Flow_18w4u31" sourceRef="UserTask_ReviewOrdersReadyForDelivery" targetRef="Gateway_1mt5ckl" />
    <bpmn:sequenceFlow id="Flow_1xgpebs" sourceRef="Event_1en7of0" targetRef="Activity_07rb12m" />
    <bpmn:sequenceFlow id="Flow_12rjwu7" sourceRef="Activity_07rb12m" targetRef="Activity_01gpftq" />
    <bpmn:sequenceFlow id="Flow_0jdmtiw" sourceRef="Activity_01gpftq" targetRef="Event_NotificationCompleted" />
    <bpmn:sequenceFlow id="Flow_1y8rt93" sourceRef="Event_00l0ahb" targetRef="UserTask_ContactCustomer" />
    <bpmn:sequenceFlow id="Flow_ContactCustomer_To_RedeliveryPossible" sourceRef="UserTask_ContactCustomer" targetRef="Gateway_RedeliveryPossible" />
    <bpmn:sequenceFlow id="Flow_RedeliveryPossible_No_To_SendFailedNotice" name="No" sourceRef="Gateway_RedeliveryPossible" targetRef="EndEvent_DeliveryFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=redeliveryPossible = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="EndEvent_DeliveryFailed" name="Delivery failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="delivery_failed" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RedeliveryPossible_No_To_SendFailedNotice</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_060mgml" />
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DeliveryPlanningDispatch">
    <bpmndi:BPMNPlane id="BPMNPlane_DeliveryPlanningDispatch" bpmnElement="Collaboration_DeliveryPlanningDispatch">
      <bpmndi:BPMNShape id="Participant_Customer_di" bpmnElement="Participant_Customer" isHorizontal="true">
