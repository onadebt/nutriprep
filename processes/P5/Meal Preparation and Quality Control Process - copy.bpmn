  <bpmn:collaboration id="Collaboration_MealPreparationQualityControl" name="Meal Preparation and Quality Control Process">
    <bpmn:participant id="Participant_NutriPrep" name="Nutri Prep" processRef="Process_zgzcjpz" />
  </bpmn:collaboration>
  <bpmn:process id="Process_zgzcjpz" name="Meal Preparation and Quality Control Process" isExecutable="true">
    <bpmn:laneSet id="LaneSet_MealPreparationQualityControl">
      <bpmn:lane id="Lane_OrderingSystem" name="Ordering System">
        <bpmn:flowNodeRef>ServiceTask_GeneratePreparationChecklist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_UpdateMealBatchStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_MarkMealsReadyForDispatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_MealsReadyForDispatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0f5x6xe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_LoadProductionPlan</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_FoodQualityAssistant" name="Food Quality Assistant">
        <bpmn:flowNodeRef>Gateway_QualityOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_DecideReworkAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0avq6st</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_KitchenTeam" name="Kitchen Team">
        <bpmn:flowNodeRef>Gateway_0tp2hmf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_PrepareIngredients</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_CookMeals</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1u0mw9z</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_PortionAndPackMeals</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_MoveMealsToDispatchArea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ReworkMeals</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReworkPossible</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_KitchenManager" name="Kitchen Manager">
        <bpmn:flowNodeRef>StartEvent_ProductionPlanReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ReviewProductionPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_AssignKitchenWork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_RecordRejectedBatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_BatchRejected</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:dataObjectReference id="DataObjectReference_ProductionPlan" name="Production plan" dataObjectRef="DataObject_ProductionPlan" />
    <bpmn:dataObject id="DataObject_ProductionPlan" name="Production plan" />
    <bpmn:serviceTask id="ServiceTask_GeneratePreparationChecklist" name="Generate preparation checklist" camunda:type="external" camunda:topic="generate-preparation-checklist">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generate-prep-checklist" />
        <zeebe:ioMapping>
          <zeebe:input source="=productionPlan" target="productionPlan" />
          <zeebe:output source="=preparationChecklist" target="preparationChecklist" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0ouhh0n</bpmn:incoming>
      <bpmn:outgoing>Flow_GenerateChecklist_To_PrepareIngredients</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_18jad0l">
        <bpmn:targetRef>DataObjectReference_PreparationChecklist</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_0tp2hmf">
      <bpmn:incoming>Flow_GenerateChecklist_To_PrepareIngredients</bpmn:incoming>
      <bpmn:incoming>Flow_AssignKitchenWork_To_GenerateChecklist</bpmn:incoming>
      <bpmn:outgoing>Flow_1n465n8</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:startEvent id="StartEvent_ProductionPlanReady" name="Production plan ready">
      <bpmn:outgoing>Flow_Start_To_LoadProductionPlan</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_ReviewProductionPlan" name="Review production plan">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="review-production-plan-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=productionPlan" target="productionPlan" />
          <zeebe:input source="=mealBatchIds" target="mealBatchIds" />
          <zeebe:input source="=productionDate" target="productionDate" />
          <zeebe:output source="=true" target="planApproved" />
          <zeebe:output source="=reviewNotes" target="reviewNotes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1z03l9n</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewProductionPlan_To_AssignKitchenWork</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_AssignKitchenWork" name="Assign kitchen work">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="assign-kitchen-work-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=productionPlan" target="productionPlan" />
          <zeebe:input source="=preparationChecklist" target="preparationChecklist" />
          <zeebe:input source="=productionDate" target="productionDate" />
          <zeebe:input source="=mealBatchIds" target="mealBatchIds" />
          <zeebe:output source="=shiftLeader" target="shiftLeader" />
          <zeebe:output source="=teamSize" target="teamSize" />
          <zeebe:output source="=priority" target="priority" />
          <zeebe:output source="=assignmentNotes" target="assignmentNotes" />
          <zeebe:output source="=true" target="kitchenWorkAssigned" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ReviewProductionPlan_To_AssignKitchenWork</bpmn:incoming>
      <bpmn:outgoing>Flow_AssignKitchenWork_To_GenerateChecklist</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataObjectReference_PreparationChecklist" name="Preparation checklist" dataObjectRef="DataObject_PreparationChecklist" />
    <bpmn:dataObject id="DataObject_PreparationChecklist" name="Preparation checklist" />
    <bpmn:userTask id="UserTask_PrepareIngredients" name="Prepare ingredients">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="prepare-ingredients-form" />
        <zeebe:ioMapping>
